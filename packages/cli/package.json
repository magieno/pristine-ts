{
  "name": "@pristine-ts/cli",
  "version": "2.0.13",
  "description": "",
  "module": "dist/lib/esm/cli.module.js",
  "main": "dist/lib/cjs/cli.module.js",
  "types": "dist/types/cli.module.d.ts",
  "bin": {
    "pristine": "dist/bin/pristine.cjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/build-bin.mjs",
    "prepublish": "npm run build",
    "test": "jest",
    "test:cov": "jest --coverage",
    "pristine:command": "pristine help"
  },
  "files": [
    "dist"
  ],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "@pristine-ts/common": "file:../common",
    "@pristine-ts/configuration": "file:../configuration",
    "@pristine-ts/core": "file:../core",
    "@pristine-ts/data-mapping": "file:../data-mapping",
    "@pristine-ts/data-mapping-common": "file:../data-mapping-common",
    "@pristine-ts/file": "file:../file",
    "@pristine-ts/logging": "file:../logging",
    "@pristine-ts/metadata": "^1.0.16",
    "@pristine-ts/observability": "file:../observability",
    "@pristine-ts/telemetry": "file:../telemetry",
    "@pristine-ts/validation": "file:../validation",
    "jiti": "^2.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "jest": {
    "transform": {
      ".(ts|tsx)": "ts-jest"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "strictNullChecks": false
        }
      }
    },
    "testEnvironment": "node",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    },
    "collectCoverageFrom": [
      "src/*.{js,ts}"
    ]
  },
  "gitHead": "112f715bf4ac6467192d416aa6e419f772b77c58",
  "repository": {
    "type": "git",
    "url": "https://github.com/magieno/pristine-ts.git",
    "directory": "packages/cli"
  }
}
