{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "expand",
  "entryPoints": [
    "packages/auth0/src",
    "packages/aws/src",
    "packages/aws-api-gateway/src",
    "packages/aws-cognito/src",
    "packages/aws-scheduling/src",
    "packages/aws-xray/src",
    "packages/cli/src",
    "packages/cloudflare/src",
    "packages/common/src",
    "packages/configuration/src",
    "packages/core/src",
    "packages/data-mapping/src",
    "packages/data-mapping-common/src",
    "packages/express/src",
    "packages/file/src",
    "packages/http/src",
    "packages/jwt/src",
    "packages/logging/src",
    "packages/mysql/src",
    "packages/mysql-common/src",
    "packages/networking/src",
    "packages/opensearch/src",
    "packages/redis/src",
    "packages/scheduling/src",
    "packages/security/src",
    "packages/sentry/src",
    "packages/stripe/src",
    "packages/telemetry/src",
    "packages/validation/src"
  ],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/node_modules/**",
    "**/dist/**"
  ],
  "out": "docs/getting-started/13-reference/api",
  "name": "Pristine API Reference",
  "readme": "docs/getting-started/13-reference/README-typedoc.md",
  "tsconfig": "tsconfig.json",
  "skipErrorChecking": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "excludeExternals": true,
  "categorizeByGroup": true,
  "navigation": {
    "includeCategories": true,
    "includeGroups": true,
    "includeFolders": true
  },
  "githubPages": false,
  "hideGenerator": true,
  "includeVersion": true,
  "sort": ["source-order"],
  "kindSortOrder": [
    "Class",
    "Interface",
    "TypeAlias",
    "Enum",
    "Function",
    "Variable"
  ],
  "treatWarningsAsErrors": false,
  "logLevel": "Info"
}
